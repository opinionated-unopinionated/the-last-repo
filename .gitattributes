# Default: normalize line endings to LF in the repo, auto-detect binary files.
* text=auto eol=lf

# Source code — explicit text + LF (defensive against odd platform defaults)
*.c        text eol=lf
*.h        text eol=lf
*.cc       text eol=lf
*.cpp      text eol=lf
*.hpp      text eol=lf
*.cs       text eol=lf
*.go       text eol=lf
*.java     text eol=lf
*.kt       text eol=lf
*.kts      text eol=lf
*.scala    text eol=lf
*.rb       text eol=lf
*.py       text eol=lf
*.rs       text eol=lf
*.swift    text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.vue      text eol=lf
*.svelte   text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.sass     text eol=lf
*.less     text eol=lf
*.html     text eol=lf
*.htm      text eol=lf
*.xml      text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.ini      text eol=lf

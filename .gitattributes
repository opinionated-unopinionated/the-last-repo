*.txt      text eol=lf
*.sql      text eol=lf
*.proto    text eol=lf
*.graphql  text eol=lf
*.gql      text eol=lf

# Shell + build scripts must be LF even on Windows checkouts
*.sh       text eol=lf
*.bash     text eol=lf
*.zsh      text eol=lf
Makefile   text eol=lf
makefile   text eol=lf
*.mk       text eol=lf
Dockerfile text eol=lf

# Windows-only scripts keep CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Lockfiles — text but mark as generated to collapse diffs in review tools
package-lock.json    text eol=lf linguist-generated=true
yarn.lock            text eol=lf linguist-generated=true
pnpm-lock.yaml       text eol=lf linguist-generated=true
bun.lockb            binary
poetry.lock          text eol=lf linguist-generated=true
Pipfile.lock         text eol=lf linguist-generated=true
go.sum               text eol=lf linguist-generated=true
Cargo.lock           text eol=lf linguist-generated=true
composer.lock        text eol=lf linguist-generated=true
Gemfile.lock         text eol=lf linguist-generated=true

